# Copy to .env.local and fill in once you create a Supabase project.
# The app runs fully without these — they only enable "save / email my plan".
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Mapbox public token (starts with pk.) — enables the visual area-picker map.
# Without it, the wizard falls back to the list picker. Get one free at
# https://account.mapbox.com → Tokens → Default public token.
NEXT_PUBLIC_MAPBOX_TOKEN=
# Optional custom Mapbox style URL (mapbox://styles/...). Defaults to light-v11.
NEXT_PUBLIC_MAPBOX_STYLE=
